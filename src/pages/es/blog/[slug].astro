---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'es' && !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^es\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()}`;
---

<Layout title={`${post.data.title} – ai-CABIN 1701`} lang="es">
  <Header lang="es" />

  <article class="post">
    {post.data.hero && (
      <div class="post-hero">
        <img src={post.data.hero} alt="" />
      </div>
    )}

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        <span class="post-author">Captain Seina</span>
        <span class="post-sep">•</span>
        <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmtDate(post.data.date)}</time>
      </p>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <nav class="post-foot">
      <a href={`${base}es/blog/`}>← Volver al B*LOG</a>
    </nav>
  </article>

  <Footer lang="es" />
</Layout>

<style>
  .post {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }
  .post-hero {
    margin: 0 -1.5rem 2.5rem;
    overflow: hidden;
  }
  .post-hero img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .post-header h1 {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 600;
    font-size: 2.4rem;
    line-height: 1.2;
    color: var(--color-tagline);
    margin: 0 0 1rem;
  }
  .post-meta {
    margin: 0;
    font-family: 'Asap', sans-serif;
    font-size: 0.85rem;
    color: var(--color-tagline);
    letter-spacing: 0.04em;
  }
  .post-author { font-style: italic; }
  .post-sep { margin: 0 0.5rem; color: var(--color-primary); }

  .post-body {
    font-family: 'Lora', serif;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .post-body :global(p) { margin: 0 0 1.25rem; }
  .post-body :global(h2) {
    font-family: 'Marcellus', serif;
    font-size: 1.6rem;
    color: var(--color-primary);
    margin: 2.5rem 0 1rem;
    letter-spacing: 0.02em;
  }
  .post-body :global(h3) {
    font-family: 'Marcellus', serif;
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 2rem 0 0.75rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-tagline);
  }
  .post-body :global(strong) { color: var(--color-tagline); }
  .post-body :global(em) { color: var(--color-primary); font-style: italic; }
  .post-body :global(a) {
    color: var(--color-magenta);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
  .post-body :global(hr) {
    border: 0;
    border-top: 1px solid rgba(208, 62, 0, 0.25);
    margin: 2.5rem auto;
    max-width: 12rem;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .post-body :global(li) { margin-bottom: 0.5rem; }
  .post-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 2rem auto;
  }

  .post-foot {
    margin-top: 4rem;
    text-align: center;
    font-family: 'Asap', sans-serif;
    font-size: 0.95rem;
  }
  .post-foot a {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  @media (max-width: 640px) {
    .post-header h1 { font-size: 1.75rem; }
    .post-body { font-size: 1rem; }
  }
</style>
