---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VegapediaBody from '../../components/VegapediaBody.astro';
import raw from '../../content/vegapedia-ja.md?raw';

---

<Layout title="ai-Vegapedia — ai-CABIN 1701" lang="ja">
  <Header lang="ja" />

  <div class="ja-vegapedia">
    <VegapediaBody
      raw={raw}
      lang="ja"
      heroSub="Seina ＆ ai-Vega の語彙集"
      heroSubStar="⭐️"
      emptyBucket="新しい項目を準備中…"
    />
  </div>

  <Footer />
</Layout>

<style is:global>
  .ja-vegapedia {
    --font-label: 'Klee One', 'Hiragino Sans', 'Yu Gothic', serif;
    --font-label-plain: 'Klee One', 'Hiragino Sans', 'Yu Gothic', serif;
    --font-italic: 'Noto Sans JP', 'Hiragino Sans', 'Yu Gothic', sans-serif;
    --font-heading: 'Klee One', 'Hiragino Sans', 'Yu Gothic', serif;
  }

  /* Klee One / Noto Sans JP have no italic — drop italic styling within JA Vegapedia */
  .ja-vegapedia .hero-sub,
  .ja-vegapedia .intro-body,
  .ja-vegapedia .bucket-empty {
    font-style: normal;
  }

  /* Klee One sits well at 600 for headings; body Noto stays at 400 */
  .ja-vegapedia .entry-title {
    font-weight: 600;
  }
  .ja-vegapedia .bucket-title {
    font-weight: 600;
  }
  .ja-vegapedia .hero-sub {
    font-weight: 600;
  }
</style>
