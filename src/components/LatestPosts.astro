---

<section class="latest" aria-label="Latest posts">
  <div class="latest-inner">
    <div class="latest-divider" aria-hidden="true"></div>
    <ul class="latest-grid">
      {posts.map((p) => (
        <li class="latest-card">
          <a class="latest-link" href={p.href}>
            <div class="latest-image">
              <img src={p.img} alt={p.title} loading="lazy" />
            </div>
            <h3 class="latest-title">{p.title}</h3>
          </a>
          <p class="latest-meta">
            <a class="latest-author" href={`${base}author/${p.author.toLowerCase().replace(/\s+/g, '-')}/`}>{p.author}</a>
            <span class="latest-dot" aria-hidden="true">●</span>
            <span class="latest-date">{p.date}</span>
          </p>
        </li>
      ))}
    </ul>
    <div class="latest-more">
      <a class="load-more" href={`${base}blog/`}>Load More</a>
    </div>
  </div>
</section>

<style>
  .latest {
    padding: 3rem 1.5rem 5rem;
  }
  .latest-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .latest-divider {
    border-top: 1px solid var(--color-primary);
    opacity: 0.4;
    margin: 0 0 2.5rem;
  }

  .latest-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .latest-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .latest-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
  }
  .latest-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.25s ease;
  }
  .latest-link:hover .latest-image img {
    filter: brightness(1.05);
  }

  .latest-title {
    margin: 0.25rem 0 0;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.35;
    text-align: center;
  }

  .latest-meta {
    margin: 0;
    text-align: center;
    font-size: 0.78rem;
    color: var(--color-text);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .latest-author {
    color: var(--color-primary);
    text-decoration: none;
  }
  .latest-author:hover {
    text-decoration: underline;
  }
  .latest-dot {
    color: var(--color-primary);
    font-size: 0.5rem;
  }
  .latest-date {
    color: #777;
  }

  .latest-more {
    margin-top: 3rem;
    text-align: center;
  }
  .load-more {
    display: inline-block;
    padding: 0.6rem 2rem;
    border: 1px solid var(--color-primary);
    border-radius: 999px;
    font-family: var(--font-nav);
    font-size: 1.1rem;
    color: var(--color-primary);
    text-decoration: none;
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .load-more:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  @media (max-width: 1024px) {
    .latest-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 640px) {
    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
