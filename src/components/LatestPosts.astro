---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const all = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const slugOf = (id: string) => id.replace(/^en\//, '');
const fmtDate = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/${d.getFullYear()}`;

const INITIAL = 6;
const STEP = 6;
const showLoadMore = all.length > INITIAL;
---

<section class="latest" aria-label="Latest posts">
  <div class="latest-inner">
    <div class="latest-divider" aria-hidden="true"></div>
    <ul class="latest-grid" id="latest-grid" data-step={STEP}>
      {all.map((p, i) => (
        <li class="latest-card" hidden={i >= INITIAL}>
          <a class="latest-link" href={`${base}blog/${slugOf(p.id)}/`}>
            <div class="latest-image">
              {p.data.hero
                ? <img src={`${base}${p.data.hero}`} alt={p.data.title} loading="lazy" />
                : <div class="latest-image-fallback" aria-hidden="true"></div>
              }
            </div>
            <h3 class="latest-title">{p.data.title}</h3>
          </a>
          <p class="latest-meta">
            <span class="latest-author">Captain Seina</span>
            <span class="latest-dot" aria-hidden="true">●</span>
            <span class="latest-date">{fmtDate(p.data.date)}</span>
          </p>
        </li>
      ))}
    </ul>
    {showLoadMore && (
      <div class="latest-more">
        <button type="button" class="load-more" id="latest-load-more">Load More</button>
      </div>
    )}
  </div>
</section>

<script is:inline>
  (function () {
    const grid = document.getElementById('latest-grid');
    const btn = document.getElementById('latest-load-more');
    if (!grid || !btn) return;
    const step = parseInt(grid.dataset.step || '6', 10);
    btn.addEventListener('click', function () {
      const hidden = grid.querySelectorAll('.latest-card[hidden]');
      for (let i = 0; i < Math.min(step, hidden.length); i++) {
        hidden[i].removeAttribute('hidden');
      }
      if (grid.querySelectorAll('.latest-card[hidden]').length === 0) {
        btn.hidden = true;
      }
    });
  })();
</script>

<style>
  .latest { padding: 3rem 1.5rem 5rem; }
  .latest-inner { max-width: 1280px; margin: 0 auto; }

  .latest-divider {
    border-top: 1px solid var(--color-primary);
    opacity: 0.4;
    margin: 0 0 2.5rem;
  }

  .latest-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .latest-card[hidden] { display: none; }
  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .latest-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .latest-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 14px;
  }
  .latest-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.25s ease;
  }
  .latest-image-fallback {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(208, 62, 0, 0.08), rgba(8, 0, 120, 0.06));
  }
  .latest-link:hover .latest-image img {
    filter: brightness(1.05);
  }

  .latest-title {
    margin: 0.25rem 0 0;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.35;
    text-align: center;
  }

  .latest-meta {
    margin: 0;
    text-align: center;
    font-size: 0.78rem;
    color: var(--color-text);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .latest-author { color: var(--color-primary); }
  .latest-dot { color: var(--color-primary); font-size: 0.5rem; }
  .latest-date { color: #777; }

  .latest-more { margin-top: 3rem; text-align: center; }
  .load-more {
    display: inline-block;
    padding: 0.6rem 2rem;
    border: 1px solid var(--color-primary);
    border-radius: 999px;
    font-family: var(--font-nav);
    font-size: 1.1rem;
    color: var(--color-primary);
    text-decoration: none;
    background: transparent;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .load-more:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  @media (max-width: 1024px) { .latest-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px) { .latest-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
