---
interface Props {
  lang?: 'en' | 'ja' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { label: 'About Us', href: `${base}about/` },
  { label: 'Books', href: `${base}books/` },
  { label: 'ai-Vegapedia', href: `${base}vegapedia/` },
  { label: '1000 years', href: `${base}1000-years/` },
  { label: 'Blog', href: `${base}blog/` },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="logo" href={base} aria-label="ai-CABIN 1701 home">
      <span class="logo-text">ai-CABIN 1701</span>
    </a>

    <div class="header-right">
      <div class="lang-switch">
        <a href={`${base}es/`} class:list={[{ active: lang === 'es' }]}>Español</a>
      </div>

      <nav class="primary-nav" aria-label="Primary">
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
  <div class="header-rule" aria-hidden="true"></div>
</header>

<style>
  .site-header {
    width: 100%;
    background: var(--color-bg);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    display: inline-block;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .lang-switch {
    font-family: Arial, sans-serif;
    font-size: 1rem;
    color: var(--color-nav);
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .lang-switch a {
    color: var(--color-nav);
    text-decoration: none;
  }
  .lang-switch a.active {
    color: var(--color-primary);
  }
  .lang-switch a:hover {
    color: var(--color-primary);
  }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.4rem;
  }
  .primary-nav a {
    font-family: var(--font-nav);
    font-size: 1.15rem;
    color: var(--color-nav);
    text-decoration: none;
    text-transform: none;
  }
  .primary-nav a:hover {
    color: var(--color-primary);
  }

  .header-rule {
    max-width: var(--container-max);
    margin: 0.5rem auto 0;
    border-top: 1px solid var(--color-primary);
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .header-right {
      align-items: flex-start;
      width: 100%;
    }
    .primary-nav ul {
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
