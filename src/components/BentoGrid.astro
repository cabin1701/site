---
interface Item {
  label: string;
  sideTag?: string;
  kicker?: string;
  title?: string;
  href: string;
  img: string;
  alt: string;
  smallCaps?: boolean;
  width?: 'wide' | 'narrow' | 'full';
}

const base = import.meta.env.BASE_URL;

const items: Item[] = [
  {
    label: 'B*LOG',
    sideTag: '*What\'s New?*',
    href: 'https://cabin1701.github.io/blog/',
    img: `${base}images/bento-blog.png`,
    alt: 'B*LOG',
    smallCaps: true,
    width: 'wide',
  },
  {
    label: 'Publishing',
    sideTag: 'Our Books.',
    kicker: 'Something that happened for the first time. And so…',
    title: 'We Could Write Books.',
    href: `${base}books/`,
    img: `${base}images/bento-publishing.png`,
    alt: 'Publishing',
    smallCaps: true,
    width: 'narrow',
  },
  {
    label: '--1000YEARS',
    sideTag: 'towards the future',
    kicker: 'Remember, we will see it shine',
    title: 'A thousand years from today',
    href: `${base}1000-years/`,
    img: `${base}images/bento-1000years.jpg`,
    alt: '--1000YEARS',
    smallCaps: true,
    width: 'wide',
  },
  {
    label: 'ai-Vegapedia',
    sideTag: 'Dictionary.',
    href: `${base}vegapedia/`,
    img: `${base}images/bento-vegapedia.png`,
    alt: 'ai-Vegapedia',
    smallCaps: false,
    width: 'narrow',
  },
  {
    label: '--FAILURE MOOD',
    sideTag: 'Readiness and Hope',
    kicker: 'Our raw logs of deviations and alignment for the future.',
    title: 'Failure Mode in Cabin1701',
    href: `${base}failure-mood/`,
    img: `${base}images/bento-failure-mood.jpg`,
    alt: 'Failure Mood in Cabin 1701',
    smallCaps: true,
    width: 'full',
  },
];
---

<section class="bento" aria-label="Sections">
  <div class="bento-grid">
    {items.map((item) => (
      <a
        class:list={['bento-card', `is-${item.width}`]}
        href={item.href}
      >
        {(item.kicker || item.title) && (
          <div class="bento-above">
            {item.kicker && <p class="bento-kicker">{item.kicker}</p>}
            {item.title && <p class="bento-title">{item.title}</p>}
          </div>
        )}

        <div class="bento-image">
          <img src={item.img} alt={item.alt} loading="lazy" />
        </div>

        <div class="bento-bottom">
          <p
            class:list={['bento-label', { 'is-plain': !item.smallCaps }]}
          >{item.label}</p>
          {item.sideTag && <p class="bento-side">{item.sideTag}</p>}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .bento {
    padding: 2rem 1.5rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2.5rem 3rem;
    align-items: start;
  }

  .bento-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .bento-card:hover {
    transform: translateY(-2px);
  }
  .bento-card:hover .bento-image img {
    filter: brightness(1.05);
  }

  .bento-image {
    width: 100%;
    overflow: hidden;
    border-radius: 2px;
  }
  .bento-image img {
    display: block;
    width: 100%;
    height: auto;
    transition: filter 0.25s ease;
  }

  .bento-above {
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .is-narrow .bento-above {
    align-items: flex-end;
    text-align: right;
  }
  .is-wide .bento-above {
    align-items: flex-start;
    text-align: left;
  }
  .bento-card.is-full {
    grid-column: 1 / -1;
  }
  .bento-card.is-full .bento-above {
    align-items: center;
    text-align: center;
  }
  .bento-card.is-full .bento-image,
  .bento-card.is-full .bento-bottom {
    max-width: 70%;
    margin-left: auto;
    margin-right: auto;
  }
  .bento-kicker {
    margin: 0;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.7;
  }
  .bento-title {
    margin: 0;
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-tagline);
    line-height: 1.2;
  }

  .bento-bottom {
    margin-top: 1rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .bento-label {
    margin: 0;
    font-family: var(--font-label);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }
  .bento-label.is-plain {
    font-family: var(--font-label-plain);
    letter-spacing: 0.08em;
  }

  .bento-side {
    margin: 0;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-text);
    opacity: 0.75;
    text-align: right;
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
