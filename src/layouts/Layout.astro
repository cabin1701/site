---
interface Props {
  title?: string;
  lang?: string;
}

const { title = 'Cabin 1701', lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;

const siteOrigin = 'https://cabin1701.com';
const currentPath = Astro.url.pathname;
const enPath = currentPath.startsWith('/es/') || currentPath === '/es'
  ? currentPath.replace(/^\/es\/?/, '/')
  : currentPath;
const esPath = currentPath.startsWith('/es/') || currentPath === '/es'
  ? currentPath
  : '/es' + (currentPath === '/' ? '/' : currentPath);
const enUrl = siteOrigin + enPath;
const esUrl = siteOrigin + esPath;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="kv21UanIMftmtRXyXw4MGyReLh29s12-yxjbLs8vo-o" />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Alice&family=Asap:ital,wght@0,400..700;1,400..700&family=Caladea:ital,wght@0,400;0,700;1,400;1,700&family=Italianno&family=Lora:ital,wght@0,400..700;1,400..700&family=Marcellus&family=Marcellus+SC&family=Nunito:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Pathway+Gothic+One&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
